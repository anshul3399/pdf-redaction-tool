# Auto detect text files and normalize line endings to LF
* text=auto

# Python
*.py text eol=lf
*.pyw text eol=lf
*.pyx text eol=lf
*.pyi text eol=lf

# Markdown
*.md text eol=lf
*.markdown text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Config files
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Documentation
*.txt text eol=lf
LICENSE text eol=lf
CHANGELOG.md text eol=lf
CONTRIBUTING.md text eol=lf
README.md text eol=lf
QUICKSTART.md text eol=lf

# Binary files
*.pdf binary
*.jpg binary
*.png binary
